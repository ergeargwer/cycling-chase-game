{
  "name": "cycling-chase-game",
  "version": "1.0.0",
  "description": "智慧騎行 追逐模式",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "predev": "tsc -p tsconfig.electron.json",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "dist:pi": "npm run build && electron-builder --linux --arm64",
    "dist:win": "npm run build && electron-builder --win --x64",
    "postinstall": "electron-rebuild -f -w @abandonware/noble"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-15",
    "electron": "^32.0.0",
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron-builder": "^25.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  }
}
